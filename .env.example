# ─── Social OAuth credentials ────────────────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# Each platform requires a registered developer app.

# Google (Maps / Google account)
# → https://console.cloud.google.com/ → APIs & Services → Credentials
# → Create OAuth 2.0 Client ID (Web application)
# → Add http://localhost:5173/oauth/callback as an Authorised redirect URI
VITE_GOOGLE_CLIENT_ID=

# Instagram (via Meta for Developers)
# → https://developers.facebook.com/apps/ → Create App → Instagram Basic Display
# → Add http://localhost:5173/oauth/callback as a Valid OAuth Redirect URI
VITE_INSTAGRAM_APP_ID=

# TikTok (Login Kit)
# → https://developers.tiktok.com/ → Manage Apps → Create App
# → Add http://localhost:5173/oauth/callback as a Redirect URI
VITE_TIKTOK_CLIENT_KEY=

# Facebook
# → https://developers.facebook.com/apps/ → Create App → Consumer
# → Add http://localhost:5173/oauth/callback as a Valid OAuth Redirect URI
VITE_FACEBOOK_APP_ID=
